classDiagram
    class Owner {
        +str name
        +int available_minutes
        +list~str~ preferences
        +add_pet(pet: Pet)
        +remove_pet(pet_name: str)
        +get_pets() list~Pet~
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +add_task(task: Task)
        +remove_task(task_name: str)
        +get_tasks() list~Task~
    }

    class Task {
        +str name
        +str category
        +int duration_minutes
        +str priority
        +str recurrence
        +is_due_today() bool
        +get_priority_value() int
    }

    class Scheduler {
        +Owner owner
        +Pet pet
        +date date
        +list~Task~ scheduled_tasks
        +list~Task~ skipped_tasks
        +generate_plan() list~Task~
        +sort_tasks(tasks: list~Task~) list~Task~
        +filter_by_time(tasks: list~Task~) list~Task~
        +explain_plan() str
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler --> Owner : plans for
    Scheduler --> Pet : schedules care for
    Scheduler ..> Task : reads and orders
